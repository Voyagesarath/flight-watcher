# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# .env is gitignored — your token never gets committed.
#
# Where these come from (same values you'd put in GitHub Secrets):
#   TELEGRAM_BOT_TOKEN — from @BotFather when you create the bot
#   TELEGRAM_CHAT_ID   — open https://api.telegram.org/bot<TOKEN>/getUpdates
#                        after messaging your bot, copy chat.id

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
